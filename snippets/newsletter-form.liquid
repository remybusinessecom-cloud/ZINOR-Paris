{% comment %}
  ============================================================
  ZINOR PARIS — Snippet formulaire newsletter
  Utilise le form 'customer' Shopify avec accepts_marketing.
  Inline form, validation HTML5 native, message succès intégré.

  Usage : {% render 'newsletter-form' %}
  ============================================================
{% endcomment %}

<div class="zinor-newsletter" data-newsletter>
  {%- form 'customer', class: 'zinor-newsletter__form' -%}
    {% comment %} Input caché — flag accepts_marketing pour la newsletter {% endcomment %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <input type="hidden" name="contact[accepts_marketing]" value="true">

    {%- if form.posted_successfully? -%}
      <p class="zinor-newsletter__success" role="status">
        Merci. Vous êtes inscrit·e au cercle.
      </p>
    {%- else -%}
      <label for="newsletter-email" class="visually-hidden">Adresse e-mail</label>

      <div class="zinor-newsletter__group">
        <input
          type="email"
          id="newsletter-email"
          name="contact[email]"
          class="zinor-newsletter__input"
          placeholder="votre@email.com"
          autocomplete="email"
          required>

        <button type="submit" class="zinor-newsletter__submit">
          S'inscrire
          <span aria-hidden="true">→</span>
        </button>
      </div>

      {%- if form.errors -%}
        <p class="zinor-newsletter__error" role="alert">
          {%- for field in form.errors -%}
            {{ form.errors.messages[field] }}{% unless forloop.last %} · {% endunless %}
          {%- endfor -%}
        </p>
      {%- endif -%}
    {%- endif -%}
  {%- endform -%}
</div>
