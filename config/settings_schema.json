      },
      {
        "type": "color",
        "id": "color_accent_secondary",
        "label": "Accent secondaire — Bleu Nuit",
        "default": "#1B2A4A",
        "info": "Couleur du cadran — touches secondaires"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Texte principal",
        "default": "#F5F0EB",
        "info": "Blanc chaud — texte global"
      }
    ]
  },
  {
    "name": "Typographie",
    "settings": [
      {
        "type": "paragraph",
        "content": "Les polices sont chargées via Google Fonts depuis layout/theme.liquid : Cormorant Garamond (titres) et Inter (corps)."
      },
      {
