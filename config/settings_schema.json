      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok"
      }
    ]
  },
  {
    "name": "Édition limitée",
    "settings": [
      {
        "type": "header",
        "content": "First Edition — Élégance"
      },
      {
        "type": "paragraph",
