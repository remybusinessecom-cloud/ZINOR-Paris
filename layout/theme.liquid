<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {# ============================================================
       ZINOR PARIS — Maison horlogère parisienne indépendante
       Layout principal du thème — Shopify Online Store 2.0
       ============================================================ #}

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_background | default: '#0A0A0A' }}">

    {# Préconnexions performance — Google Fonts et CDN Shopify #}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {# Typographie — Cormorant Garamond (titres) + Inter (corps)
       display=swap pour ne pas bloquer le rendu (Core Web Vitals) #}
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet">

    {# Favicon #}
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {# SEO — title, description, canonical, Open Graph #}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' -}}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">

    {# Open Graph — partage social #}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
    {%- if page_description -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}
    {%- if page_image -%}
      <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}

    {# Twitter Card #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">

    {# Feuille de style principale du thème #}
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {# Variables CSS injectées depuis les paramètres du thème #}
    <style>
      :root {
        --color-background: {{ settings.color_background | default: '#0A0A0A' }};
        --color-surface: {{ settings.color_surface | default: '#141414' }};
        --color-accent: {{ settings.color_accent | default: '#C4956A' }};
        --color-accent-secondary: {{ settings.color_accent_secondary | default: '#1B2A4A' }};
        --color-text: {{ settings.color_text | default: '#F5F0EB' }};
      }
    </style>

    {# Hook obligatoire Shopify — doit être présent dans <head> #}
    {{ content_for_header }}
  </head>

  <body class="template-{{ template | replace: '.', '-' | handle }}">
    {# Lien d'évitement — accessibilité clavier #}
    <a href="#MainContent" class="skip-to-content">
      {{ 'accessibility.skip_to_content' | t }}
    </a>

    {# ====== EN-TÊTE — sticky avec navigation principale ====== #}
    <header class="site-header" id="SiteHeader" data-sticky-header>
      <div class="container site-header__inner">
        {# Logo — texte par défaut, image si définie dans les réglages #}
        <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 240 | image_tag:
              loading: 'eager',
              width: 120,
              height: 40,
              alt: shop.name
            }}
          {%- else -%}
            <span class="site-header__logo-text">ZINOR <em>Paris</em></span>
          {%- endif -%}
        </a>

        {# Navigation principale — basée sur le menu Shopify "main-menu" #}
        <nav class="site-nav" aria-label="{{ 'accessibility.main_navigation' | t }}">
          <ul class="site-nav__list">
            {%- for link in linklists.main-menu.links -%}
              <li class="site-nav__item">
                <a href="{{ link.url }}" class="site-nav__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        {# Actions — panier #}
        <div class="site-header__actions">
          <a href="{{ routes.cart_url }}" class="site-header__cart-link" aria-label="{{ 'cart.general.title' | t }}">
            {{ 'cart.general.title' | t }}
            <span class="site-header__cart-count" data-cart-count>({{ cart.item_count }})</span>
          </a>
        </div>
      </div>
    </header>

    {# ====== CONTENU PRINCIPAL ====== #}
    <main id="MainContent" class="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {# ====== PIED DE PAGE — minimaliste ====== #}
    <footer class="site-footer" role="contentinfo">
      <div class="container site-footer__inner">
        <div class="site-footer__brand">
          <p class="site-footer__title">ZINOR <em>Paris</em></p>
          <p class="site-footer__tagline">{{ 'general.footer.tagline' | t }}</p>
        </div>

        <div class="site-footer__columns">
          {%- if linklists.footer.links.size > 0 -%}
            <nav class="site-footer__nav" aria-label="{{ 'accessibility.footer_navigation' | t }}">
              <ul class="site-footer__list">
                {%- for link in linklists.footer.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </nav>
          {%- endif -%}

          {# Réseaux sociaux — Instagram principalement #}
          {%- if settings.social_instagram_link != blank -%}
            <div class="site-footer__social">
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                Instagram
              </a>
            </div>
          {%- endif -%}
        </div>

        <div class="site-footer__legal">
          <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }} — {{ 'general.footer.legal' | t }}</p>
        </div>
      </div>
    </footer>

    {# Script principal du thème — defer pour ne pas bloquer le rendu #}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
