<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% comment %} ============================================================
       ZINOR PARIS — Maison horlogère parisienne indépendante
       Layout principal du thème — Shopify Online Store 2.0
       ============================================================ {% endcomment %}

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_background | default: '#0A0A0A' }}">

    {% comment %} Préconnexions performance — Google Fonts et CDN Shopify {% endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% comment %} Typographie — Cormorant Garamond (titres) + Inter (corps)
       display=swap pour ne pas bloquer le rendu (Core Web Vitals) {% endcomment %}
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet">

    {% comment %} Favicon {% endcomment %}
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% comment %} SEO — title, description, canonical, Open Graph {% endcomment %}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' -}}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">

    {% comment %} Open Graph — partage social {% endcomment %}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
    {%- if page_description -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}
    {%- if page_image -%}
      <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}

    {% comment %} Twitter Card {% endcomment %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">

    {% comment %} Feuille de style principale du thème {% endcomment %}
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {% comment %} Variables CSS injectées depuis les paramètres du thème {% endcomment %}
    <style>
      :root {
        --color-background: {{ settings.color_background | default: '#0A0A0A' }};
        --color-surface: {{ settings.color_surface | default: '#141414' }};
        --color-accent: {{ settings.color_accent | default: '#C4956A' }};
        --color-accent-secondary: {{ settings.color_accent_secondary | default: '#1B2A4A' }};
        --color-text: {{ settings.color_text | default: '#F5F0EB' }};
      }
    </style>

    {% comment %} Hook obligatoire Shopify — doit être présent dans <head> {% endcomment %}
    {{ content_for_header }}
  </head>

  <body class="template-{{ template | replace: '.', '-' | handle }}">
    {% comment %} Lien d'évitement — accessibilité clavier {% endcomment %}
    <a href="#MainContent" class="skip-to-content">
      {{ 'accessibility.skip_to_content' | t }}
    </a>

    {% comment %} ====== EN-TÊTE — sticky avec navigation principale ====== {% endcomment %}
    <header class="site-header" id="SiteHeader" data-sticky-header>
      <div class="container site-header__inner">

        {% comment %} Bouton burger — visible uniquement mobile (≤768px) {% endcomment %}
        <button
          type="button"
          class="site-header__burger"
          data-menu-toggle
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="MobileMenu">
          {% render 'icon-menu' %}
        </button>

        {% comment %} Logo — texte par défaut, image si définie dans les réglages {% endcomment %}
        <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 240 | image_tag:
              loading: 'eager',
              width: 120,
              height: 40,
              alt: shop.name
            }}
          {%- else -%}
            <span class="site-header__logo-text">ZINOR <em>Paris</em></span>
          {%- endif -%}
        </a>

        {% comment %} Navigation desktop — masquée ≤768px (remplacée par le menu mobile) {% endcomment %}
        <nav class="site-nav" aria-label="{{ 'accessibility.main_navigation' | t }}">
          <ul class="site-nav__list">
            {%- for link in linklists.main-menu.links -%}
              <li class="site-nav__item">
                <a href="{{ link.url }}" class="site-nav__link">{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        {% comment %} Groupe d'actions — recherche · compte · panier (toujours visibles) {% endcomment %}
        <div class="site-header__actions">
          <button
            type="button"
            class="header__icon-button"
            data-search-toggle
            aria-label="Rechercher"
            aria-expanded="false"
            aria-controls="SearchOverlay">
            {% render 'icon-search' %}
          </button>

          <button
            type="button"
            class="header__icon-button"
            data-account-toggle
            aria-label="Espace client"
            aria-expanded="false"
            aria-controls="AccountDrawer">
            {% render 'icon-account' %}
          </button>

          <a
            href="{{ routes.cart_url }}"
            class="header__icon-button site-header__cart"
            aria-label="{{ 'cart.general.title' | t }} ({{ cart.item_count }})">
            {% render 'icon-cart' %}
            {%- if cart.item_count > 0 -%}
              <span class="site-header__cart-count" data-cart-count aria-hidden="true">
                {%- if cart.item_count > 9 -%}9+{%- else -%}{{ cart.item_count }}{%- endif -%}
              </span>
            {%- endif -%}
          </a>
        </div>
      </div>
    </header>

    {% comment %} ====== MENU MOBILE — overlay fullscreen ====== {% endcomment %}
    <div
      class="mobile-menu"
      id="MobileMenu"
      data-mobile-menu
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-label="{{ 'accessibility.main_navigation' | t }}">

      <div class="mobile-menu__header">
        <button
          type="button"
          class="mobile-menu__close"
          data-menu-close
          aria-label="Fermer le menu">
          {% render 'icon-close' %}
        </button>
      </div>

      <nav class="mobile-menu__nav" aria-label="Menu principal">
        <ul class="mobile-menu__list">
          {%- if linklists.main-menu.links.size > 0 -%}
            {%- for link in linklists.main-menu.links -%}
              <li><a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            {% comment %} Liens par défaut si le menu Shopify n'est pas configuré {% endcomment %}
            <li><a href="{{ routes.root_url }}" class="mobile-menu__link">Accueil</a></li>
            <li><a href="/collections/all" class="mobile-menu__link">Collection</a></li>
            <li><a href="/pages/notre-histoire" class="mobile-menu__link">Notre histoire</a></li>
            <li><a href="/pages/contact" class="mobile-menu__link">Contact</a></li>
          {%- endif -%}
        </ul>
      </nav>

      {% comment %} Liens secondaires (compte + suivi) — au-dessus des icônes sociales {% endcomment %}
      <ul class="mobile-menu__secondary">
        <li>
          <a href="{{ routes.account_url | default: '/account' }}" class="mobile-menu__secondary-link">
            Mon compte
          </a>
        </li>
        <li>
          <a href="/pages/suivre-commande" class="mobile-menu__secondary-link">
            Suivre ma commande
          </a>
        </li>
      </ul>

      <div class="mobile-menu__footer">
        {%- if settings.social_instagram_link != blank -%}
          <a
            href="{{ settings.social_instagram_link }}"
            class="mobile-menu__icon-link"
            target="_blank"
            rel="noopener"
            aria-label="Instagram">
            {% render 'icon-instagram' %}
          </a>
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="mobile-menu__cart-link">
          {% render 'icon-cart' %}
          <span>Panier ({{ cart.item_count }})</span>
        </a>
      </div>
    </div>

    {% comment %} ====== OVERLAY RECHERCHE — fullscreen blur ====== {% endcomment %}
    <div
      class="search-overlay"
      id="SearchOverlay"
      data-search-overlay
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-label="Rechercher">
      <button
        type="button"
        class="search-overlay__close"
        data-search-close
        aria-label="Fermer la recherche">
        {% render 'icon-close' %}
      </button>

      <form action="{{ routes.search_url }}" method="get" class="search-overlay__form" role="search">
        <label for="SearchInput" class="visually-hidden">Rechercher</label>
        <input
          type="search"
          id="SearchInput"
          name="q"
          class="search-overlay__input"
          placeholder="Rechercher une pièce…"
          autocomplete="off"
          spellcheck="false"
          data-search-input>
        {% comment %} Scope recherche produits uniquement par défaut {% endcomment %}
        <input type="hidden" name="type" value="product">
      </form>
    </div>

    {% comment %} ====== DRAWER COMPTE — backdrop + sidebar slide right ====== {% endcomment %}
    <div
      class="account-drawer-backdrop"
      data-account-backdrop
      aria-hidden="true"></div>

    <aside
      class="account-drawer"
      id="AccountDrawer"
      data-account-drawer
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      aria-label="Espace client">

      <button
        type="button"
        class="account-drawer__close"
        data-account-close
        aria-label="Fermer">
        {% render 'icon-close' %}
      </button>

      <div class="account-drawer__body">
        {%- if customer -%}
          {% comment %} ===== ÉTAT B — utilisateur connecté ===== {% endcomment %}
          <h2 class="account-drawer__greeting">
            Bonjour {{ customer.first_name | default: customer.name }}
          </h2>

          <ul class="account-drawer__menu">
            <li><a href="{{ routes.account_url }}" class="account-drawer__menu-link">Mes commandes</a></li>
            <li><a href="{{ routes.account_addresses_url }}" class="account-drawer__menu-link">Mes adresses</a></li>
            <li><a href="{{ routes.account_url }}" class="account-drawer__menu-link">Mes informations</a></li>
            <li><a href="{{ routes.account_logout_url }}" class="account-drawer__menu-link">Se déconnecter</a></li>
          </ul>
        {%- else -%}
          {% comment %} ===== ÉTAT A — utilisateur non connecté ===== {% endcomment %}
          <h2 class="account-drawer__title">
            Connectez-vous<br>pour consulter<br>vos commandes
          </h2>

          <a href="{{ routes.account_login_url }}" class="account-drawer__cta">
            Connexion
          </a>

          <p class="account-drawer__legal">
            En vous connectant, vous acceptez notre
            <a href="/policies/privacy-policy">politique de confidentialité</a>
            et nos
            <a href="/policies/terms-of-service">conditions d'utilisation</a>.
          </p>
        {%- endif -%}
      </div>

      {% comment %} ===== ÉTAT C — pied de drawer, toujours visible ===== {% endcomment %}
      <div class="account-drawer__footer">
        <a href="/pages/suivre-commande" class="account-drawer__footer-link">
          {% render 'icon-cart' %}
          <span>Suivre une commande</span>
        </a>
        <a href="{{ routes.account_url | default: '/account' }}" class="account-drawer__footer-link">
          {% render 'icon-account' %}
          <span>Mon compte</span>
        </a>
      </div>
    </aside>

    {% comment %} ====== CONTENU PRINCIPAL ====== {% endcomment %}
    <main id="MainContent" class="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {% comment %} ====== PIED DE PAGE — section éditable ====== {% endcomment %}
    {% section 'footer' %}

    {% comment %} Script principal du thème — defer pour ne pas bloquer le rendu {% endcomment %}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
