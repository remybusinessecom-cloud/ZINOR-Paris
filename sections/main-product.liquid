{% comment %}
  ============================================================
  ZINOR PARIS — Section fiche produit
  Page produit complète : galerie / informations / accordéon /
  outro full-width / sticky ATC mobile.
  Tous les contenus sont éditables via l'éditeur Shopify.
  ============================================================
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign low_stock_threshold = section.settings.low_stock_threshold | default: 20
  assign show_low_stock = section.settings.show_low_stock_badge
  assign accordion_open = section.settings.accordion_default_open | default: 'caracteristiques'
-%}

<section class="zinor-product" data-product-section>
  <div class="zinor-product__container">
    <div class="zinor-product__grid">

      {% comment %} ============================================================
         COLONNE GAUCHE — GALERIE PRODUIT
         Desktop : miniatures verticales + image principale
         Mobile  : image principale en haut, dots en bas
         ============================================================ {% endcomment %}
      <div class="zinor-product__gallery" data-product-gallery>
        {% comment %} ----- Miniatures verticales (desktop) ----- {% endcomment %}
        <div
          class="zinor-product__thumbs"
          data-product-thumbs
          role="tablist"
          aria-label="Visuels du produit"
          aria-orientation="vertical">
          {%- for image in product.images limit: 6 -%}
            <button
              type="button"
              class="zinor-product__thumb{% if forloop.first %} is-active{% endif %}"
              data-product-thumb
              data-image-index="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Visuel {{ forloop.index }} sur {{ product.images.size }}">
              {{
                image
                | image_url: width: 160
                | image_tag:
                  loading: 'lazy',
                  width: 80,
                  height: 80,
                  alt: image.alt | default: product.title
              }}
            </button>
          {%- endfor -%}
        </div>

        {% comment %} ----- Image principale — empilement de tous les visuels ----- {% endcomment %}
        <div class="zinor-product__main" data-product-main>
          {%- for image in product.images limit: 6 -%}
            <div
              class="zinor-product__image{% if forloop.first %} is-active{% endif %}"
              data-product-image
              data-image-index="{{ forloop.index0 }}"
              data-image-zoom="{{ image | image_url: width: 2400 }}">
              {{
                image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  fetchpriority: forloop.first | default: false,
                  widths: '400, 600, 900, 1200, 1600',
                  sizes: '(min-width: 1024px) 50vw, 100vw',
                  alt: image.alt | default: product.title,
                  class: 'zinor-product__main-image'
              }}
            </div>
          {%- endfor -%}

          {% comment %} Bouton zoom — fixe en bas à droite de l'image principale {% endcomment %}
          {%- if product.images.size > 0 -%}
            <button
              type="button"
              class="zinor-product__zoom-btn"
              data-product-zoom-trigger
              aria-label="Zoomer sur l'image"
              aria-controls="ProductLightbox">
              <span aria-hidden="true">+</span>
              <span class="zinor-product__zoom-tooltip">Zoomer sur l'image</span>
            </button>
          {%- endif -%}
        </div>

        {% comment %} ----- Dots (mobile uniquement, via CSS) ----- {% endcomment %}
        <div
          class="zinor-product__dots"
          role="tablist"
          aria-label="Navigation des visuels"
          data-product-dots>
          {%- for image in product.images limit: 6 -%}
            <button
              type="button"
              class="zinor-product__dot{% if forloop.first %} is-active{% endif %}"
              data-product-thumb
              data-image-index="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Visuel {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      </div>

      {% comment %} ============================================================
         COLONNE DROITE — INFOS PRODUIT
         Sticky sur desktop, normal sur mobile
         ============================================================ {% endcomment %}
      <div class="zinor-product__info">
        <p class="zinor-product__label">ZINOR PARIS</p>

        <h1 class="zinor-product__title">{{ product.title }}</h1>

        <p class="zinor-product__subtitle">
          {{ section.settings.product_subtitle | default: 'First Edition — Pièce numérotée' }}
        </p>

        <p class="zinor-product__price">{{ current_variant.price | money }}</p>

        {% comment %} Badge de stock faible — conditionnel {% endcomment %}
        {%- if show_low_stock
          and current_variant.inventory_management != blank
          and current_variant.inventory_quantity > 0
          and current_variant.inventory_quantity <= low_stock_threshold
        -%}
          <div class="zinor-product__low-stock" role="status">
            <span aria-hidden="true">⚡</span>
            Plus que {{ current_variant.inventory_quantity }} pièces disponibles
          </div>
        {%- endif -%}

        {% comment %} Séparateur fin rose gold {% endcomment %}
        <hr class="zinor-product__divider" aria-hidden="true">

        <div class="zinor-product__intro">
          {{
            section.settings.intro_text
            | default: "<p>L'Élégance n'est pas un ornement. C'est une décision. Cadran soleil bleu nuit, finition rose gold, bracelet cuir grainé cognac, mouvement SEIKO VJ32 — chaque détail choisi pour durer.</p>"
          }}
        </div>

        {% comment %} ----- FORMULAIRE ATC ----- {% endcomment %}
        <form
          method="post"
          action="{{ routes.cart_add_url }}"
          accept-charset="UTF-8"
          enctype="multipart/form-data"
          class="zinor-product__form"
          data-product-form>
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <button
            type="submit"
            class="zinor-product__atc"
            data-atc-button
            {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}
              {{ 'products.product.add_to_cart' | t | default: 'AJOUTER AU PANIER' }}
            {%- else -%}
              ÉPUISÉ
            {%- endif -%}
          </button>
        </form>

        <p class="zinor-product__reassurance">
          Livraison offerte en France · Retours 30 jours
        </p>

        {% comment %} ============================================================
           ACCORDÉON — 3 sections
           ============================================================ {% endcomment %}
        <div class="zinor-accordion" data-accordion>
          {% comment %} --- Caractéristiques --- {% endcomment %}
          <div
            class="zinor-accordion__item{% if accordion_open == 'caracteristiques' %} is-open{% endif %}"
            data-accordion-item>
            <button
              type="button"
              class="zinor-accordion__header"
              data-accordion-trigger
              aria-expanded="{% if accordion_open == 'caracteristiques' %}true{% else %}false{% endif %}"
              aria-controls="acc-panel-specs">
              <span>Caractéristiques</span>
              <span class="zinor-accordion__icon" aria-hidden="true"></span>
            </button>
            <div
              class="zinor-accordion__panel"
              id="acc-panel-specs"
              data-accordion-panel
              role="region">
              <div class="zinor-accordion__content">
                <ul class="zinor-product__specs">
                  <li>Finition : Rose gold</li>
                  <li>Diamètre : 40mm · Épaisseur : 7,8mm</li>
                  <li>Cadran : Soleil bleu nuit, index bâtons rose gold</li>
                  <li>Verre : Minéral traitement antireflet</li>
                  <li>Mouvement : SEIKO VJ32 — Quartz Japon</li>
                  <li>Fond de boîtier : Acier inoxydable 304L gravé</li>
                  <li>Bracelet : Cuir grainé cognac, 20mm</li>
                  <li>Boucle : Ardillon acier rose gold gravée "ZINOR"</li>
                  <li>Couronne : Acier rose gold gravée "Z"</li>
                  <li>Étanchéité : 3 ATM</li>
                </ul>
              </div>
            </div>
          </div>

          {% comment %} --- Édition & Livraison --- {% endcomment %}
          <div
            class="zinor-accordion__item{% if accordion_open == 'edition' %} is-open{% endif %}"
            data-accordion-item>
            <button
              type="button"
              class="zinor-accordion__header"
              data-accordion-trigger
              aria-expanded="{% if accordion_open == 'edition' %}true{% else %}false{% endif %}"
              aria-controls="acc-panel-edition">
              <span>Édition &amp; Livraison</span>
              <span class="zinor-accordion__icon" aria-hidden="true"></span>
            </button>
            <div
              class="zinor-accordion__panel"
              id="acc-panel-edition"
              data-accordion-panel
              role="region">
              <div class="zinor-accordion__content">
                <p>Édition limitée stricte à 100 exemplaires, non renouvelée.</p>
                <p>Chaque pièce numérotée individuellement.</p>
                <p>Certificat d'authenticité ZINOR PARIS inclus.</p>
                <p>Écrin premium noir et or.</p>
                <p>Livraison offerte France (5–8 jours ouvrés).</p>
                <p>International : tarifs et délais calculés au checkout.</p>
                <p>Retours acceptés sous 30 jours, pièce non portée.</p>
              </div>
            </div>
          </div>

          {% comment %} --- Notre histoire --- {% endcomment %}
          <div
            class="zinor-accordion__item{% if accordion_open == 'histoire' %} is-open{% endif %}"
            data-accordion-item>
            <button
              type="button"
              class="zinor-accordion__header"
              data-accordion-trigger
              aria-expanded="{% if accordion_open == 'histoire' %}true{% else %}false{% endif %}"
              aria-controls="acc-panel-history">
              <span>Notre histoire</span>
              <span class="zinor-accordion__icon" aria-hidden="true"></span>
            </button>
            <div
              class="zinor-accordion__panel"
              id="acc-panel-history"
              data-accordion-panel
              role="region">
              <div class="zinor-accordion__content">
                <p>ZINOR PARIS est né d'un refus : celui du superflu.</p>
                <p>L'Élégance First Edition est notre première prise de position.</p>
                <p>100 pièces. Un seul modèle. Une exigence absolue.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  {% comment %} ============================================================
     OUTRO — pleine largeur avec image de fond fixe (desktop)
     ============================================================ {% endcomment %}
  <div
    class="zinor-product__outro"
    {% if section.settings.outro_image != blank %}
      style="background-image: url('{{ section.settings.outro_image | image_url: width: 2400 }}');"
    {% endif %}>
    <div class="zinor-product__outro-overlay" aria-hidden="true"></div>
    <div class="zinor-product__outro-inner fade-in">
      <h2 class="zinor-product__outro-title">
        {{ section.settings.outro_title | default: 'Une pièce pour ceux qui savent.' }}
      </h2>
      <p class="zinor-product__outro-subtitle">
        {{ section.settings.outro_subtitle | default: 'Fabriquée pour durer. Conçue pour vous distinguer.' }}
      </p>
    </div>
  </div>

  {% comment %} ============================================================
     STICKY ATC — visible sur mobile uniquement quand l'ATC
     principal sort du viewport (toggle via JS)
     ============================================================ {% endcomment %}
  <div class="zinor-product__sticky-atc" data-sticky-atc aria-hidden="true">
    <div class="zinor-product__sticky-atc-inner">
      <p class="zinor-product__sticky-atc-price">{{ current_variant.price | money }}</p>
      <button
        type="button"
        class="zinor-product__sticky-atc-btn"
        data-sticky-atc-trigger
        {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}Ajouter au panier{%- else -%}Épuisé{%- endif -%}
      </button>
    </div>
  </div>
</section>

{% comment %} ====== LIGHTBOX ZOOM — fullscreen overlay ====== {% endcomment %}
<div
  class="product-lightbox"
  id="ProductLightbox"
  data-product-lightbox
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Vue agrandie de l'image">
  <button
    type="button"
    class="product-lightbox__close"
    data-product-lightbox-close
    aria-label="Fermer la vue agrandie">
    {% render 'icon-close' %}
  </button>
  <img
    src=""
    alt=""
    class="product-lightbox__image"
    data-product-lightbox-image>
</div>

{% comment %} JSON-LD pour le SEO produit {% endcomment %}
<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% comment %} ============================================================
   STYLES SCOPÉS
   ============================================================ {% endcomment %}
{% stylesheet %}
  /* ========== CONTENEUR & GRID ========== */
  .zinor-product {
    background-color: var(--color-background);
    color: var(--color-text);
    position: relative;
  }

  .zinor-product__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem; /* mobile : 40px 20px */
  }

  @media (min-width: 1024px) {
    .zinor-product__container {
      padding: 5rem 2.5rem; /* desktop : 80px 40px */
    }
  }

  .zinor-product__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 1024px) {
    .zinor-product__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  /* ========== GALERIE ========== */
  .zinor-product__gallery {
    display: grid;
    gap: 1rem;
  }

  /* Desktop : miniatures à gauche, image principale à droite */
  @media (min-width: 1024px) {
    .zinor-product__gallery {
      grid-template-columns: 80px 1fr;
      gap: 1.25rem;
      align-items: start;
    }
  }

  /* Miniatures verticales (desktop only) */
  .zinor-product__thumbs {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 1024px) {
    .zinor-product__thumbs {
      display: flex;
    }
  }

  .zinor-product__thumb {
    width: 80px;
    height: 80px;
    padding: 0;
    background-color: #0F0F0F;
    border: 1px solid transparent;
    cursor: pointer;
    overflow: hidden;
    opacity: 0.5;
    transition: opacity 0.2s ease, border-color 0.2s ease;
  }

  .zinor-product__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .zinor-product__thumb:hover,
  .zinor-product__thumb:focus-visible {
    opacity: 0.8;
  }

  .zinor-product__thumb.is-active {
    opacity: 1;
    border-color: var(--color-accent); /* #C4956A */
  }

  /* ========== IMAGE PRINCIPALE ==========
     Hauteurs fixes (380 mobile / 450 tablette / 600 desktop)
     Fond #0F0F0F. Images empilées en absolute, swap par classe.
     ============================================================ */
  .zinor-product__main {
    position: relative;
    width: 100%;
    height: 380px; /* mobile */
    background-color: #0F0F0F;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .zinor-product__main {
      height: 450px;
    }
  }

  @media (min-width: 1024px) {
    .zinor-product__main {
      height: 600px;
    }
  }

  /* Chaque visuel — empilé en absolute, invisible par défaut */
  .zinor-product__image {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .zinor-product__image.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .zinor-product__image img,
  .zinor-product__main-image {
    width: 100%;
    height: 100%;
    object-fit: contain; /* ne jamais couper la montre */
    object-position: center;
    display: block;
  }

  /* ========== CURSEUR DIRECTIONNEL DESKTOP ==========
     Pattern identique à la galerie produit phare de la home.
     ============================================================ */
  @media (hover: hover) and (pointer: fine) {
    .zinor-product__main {
      cursor: none;
    }
  }

  .zinor-product__cursor {
    position: absolute;
    top: 0;
    left: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: rgba(10, 10, 10, 0.55);
    border: 1px solid rgba(196, 149, 106, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 3;
  }

  .zinor-product__cursor.is-visible {
    opacity: 1;
  }

  .zinor-product__cursor svg {
    width: 20px;
    height: 20px;
    color: var(--color-accent);
    transition: transform 0.15s ease;
  }

  /* Flèche pointant gauche par défaut, pivote sur la moitié droite */
  .zinor-product__cursor.is-right svg {
    transform: rotate(180deg);
  }

  /* Tactile : pas de curseur custom */
  @media (pointer: coarse) {
    .zinor-product__cursor {
      display: none;
    }
    .zinor-product__main {
      cursor: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zinor-product__cursor svg {
      transition: none;
    }
  }

  /* ========== BOUTON ZOOM + TOOLTIP ========== */
  .zinor-product__zoom-btn {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(10, 10, 10, 0.7);
    border: 1px solid rgba(196, 149, 106, 0.35);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 4; /* au-dessus du curseur (z-3) */
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .zinor-product__zoom-btn:hover,
  .zinor-product__zoom-btn:focus-visible {
    background-color: rgba(10, 10, 10, 0.85);
    border-color: rgba(196, 149, 106, 0.7);
    outline: none;
  }

  .zinor-product__zoom-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background-color: #1A1A1A;
    color: var(--color-text);
    padding: 4px 10px;
    border-radius: 3px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0s linear 0.2s;
    pointer-events: none;
  }

  .zinor-product__zoom-btn:hover .zinor-product__zoom-tooltip,
  .zinor-product__zoom-btn:focus-visible .zinor-product__zoom-tooltip {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.2s ease, visibility 0s linear 0s;
  }

  /* ========== LIGHTBOX ZOOM ========== */
  .product-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background-color: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }

  .product-lightbox.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  .product-lightbox__image {
    max-width: 90vw;
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .product-lightbox__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .product-lightbox__close:hover,
  .product-lightbox__close:focus-visible {
    opacity: 0.7;
    outline: none;
  }

  /* Dots mobile (cachés desktop) */
  .zinor-product__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0 0;
  }

  @media (min-width: 1024px) {
    .zinor-product__dots {
      display: none;
    }
  }

  .zinor-product__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(245, 240, 235, 0.3);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 200ms ease, transform 200ms ease;
  }

  .zinor-product__dot:hover,
  .zinor-product__dot.is-active {
    background-color: var(--color-accent);
    transform: scale(1.3);
  }

  /* ========== INFOS PRODUIT ========== */
  .zinor-product__info {
    padding-left: 0;
  }

  @media (min-width: 1024px) {
    .zinor-product__info {
      padding-left: 3.75rem; /* 60px */
      position: sticky;
      top: 100px;
    }
  }

  .zinor-product__label {
    font-family: var(--font-body);
    font-size: 0.75rem; /* 12px */
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .zinor-product__title {
    font-family: var(--font-heading);
    font-size: 2rem; /* 32px mobile */
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  @media (min-width: 1024px) {
    .zinor-product__title {
      font-size: 3.25rem; /* 52px desktop */
    }
  }

  .zinor-product__subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem; /* 14px */
    color: #888;
    margin-bottom: 1.5rem;
  }

  .zinor-product__price {
    font-family: var(--font-body);
    font-size: 1.75rem; /* 28px */
    font-weight: 400;
    color: var(--color-text);
    margin-top: 1.5rem;
    margin-bottom: 0;
  }

  /* Badge stock faible */
  .zinor-product__low-stock {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: rgba(196, 149, 106, 0.15);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-top: 1rem;
  }

  /* Séparateur rose gold */
  .zinor-product__divider {
    width: 60px;
    height: 1px;
    background-color: var(--color-accent);
    border: none;
    margin: 2rem 0;
  }

  .zinor-product__intro {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .zinor-product__intro p {
    margin: 0;
  }

  /* Bouton ATC principal */
  .zinor-product__form {
    margin-top: 2.5rem;
  }

  .zinor-product__atc {
    width: 100%;
    height: 56px;
    background-color: var(--color-accent);
    color: var(--color-background);
    border: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 250ms ease, opacity 250ms ease;
  }

  .zinor-product__atc:hover:not(:disabled),
  .zinor-product__atc:focus-visible:not(:disabled) {
    background-color: #B58559; /* rose gold 10% plus sombre */
  }

  .zinor-product__atc:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .zinor-product__reassurance {
    font-family: var(--font-body);
    font-size: 0.75rem; /* 12px */
    color: #888;
    text-align: center;
    margin-top: 1rem;
  }

  /* ========== ACCORDÉON ========== */
  .zinor-accordion {
    margin-top: 3rem; /* 48px */
  }

  .zinor-accordion__item {
    border-bottom: 1px solid #1F1F1F;
  }

  .zinor-accordion__header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0; /* 20px */
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 1.125rem; /* 18px */
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: left;
    transition: color 200ms ease;
  }

  .zinor-accordion__header:hover {
    color: var(--color-accent);
  }

  /* Icône + / − (CSS pur, pas d'image) */
  .zinor-accordion__icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .zinor-accordion__icon::before,
  .zinor-accordion__icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    transition: transform 300ms ease, opacity 300ms ease;
  }

  /* Trait horizontal (le "−") */
  .zinor-accordion__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    transform: translateY(-50%);
  }

  /* Trait vertical (forme le "+") */
  .zinor-accordion__icon::after {
    left: 50%;
    top: 0;
    height: 100%;
    width: 1px;
    transform: translateX(-50%);
  }

  /* Quand ouvert : le trait vertical disparaît → reste un "−" */
  .zinor-accordion__item.is-open .zinor-accordion__icon::after {
    transform: translateX(-50%) scaleY(0);
    opacity: 0;
  }

  /* Panneau — animation max-height pour la transition douce */
  .zinor-accordion__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms ease;
  }

  .zinor-accordion__item.is-open .zinor-accordion__panel {
    max-height: 1200px; /* assez large pour les contenus */
  }

  .zinor-accordion__content {
    padding: 0.5rem 0 1.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem; /* 14px */
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .zinor-accordion__content p {
    margin: 0 0 0.5rem;
  }

  .zinor-product__specs {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .zinor-product__specs li {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 2;
    color: var(--color-text-muted);
  }

  /* ========== OUTRO ========== */
  .zinor-product__outro {
    position: relative;
    background-color: #0F0F0F;
    background-size: cover;
    background-position: center;
    padding: 7.5rem 1.5rem; /* 120px 0 */
    text-align: center;
    overflow: hidden;
  }

  /* Parallax/fixed sur desktop uniquement (pas mobile pour la perf iOS) */
  @media (min-width: 1024px) {
    .zinor-product__outro {
      background-attachment: fixed;
    }
  }

  .zinor-product__outro-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(10, 10, 10, 0.7);
    z-index: 1;
  }

  .zinor-product__outro-inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .zinor-product__outro-title {
    font-family: var(--font-heading);
    font-size: 1.75rem; /* 28px mobile */
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0;
  }

  @media (min-width: 768px) {
    .zinor-product__outro-title {
      font-size: 2.5rem; /* 40px desktop */
    }
  }

  .zinor-product__outro-subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem; /* 18px */
    line-height: 1.6;
    color: var(--color-text);
    margin-top: 1.5rem;
  }

  /* ========== STICKY ATC (mobile only) ========== */
  .zinor-product__sticky-atc {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background-color: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid #1F1F1F;
    padding: 1rem 1.25rem;
    transform: translateY(100%);
    transition: transform 300ms ease;
    pointer-events: none;
  }

  /* Visible uniquement quand .is-visible (toggled par JS) */
  .zinor-product__sticky-atc.is-visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Désactivé sur desktop */
  @media (min-width: 768px) {
    .zinor-product__sticky-atc {
      display: none;
    }
  }

  .zinor-product__sticky-atc-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .zinor-product__sticky-atc-price {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
  }

  .zinor-product__sticky-atc-btn {
    background-color: var(--color-accent);
    color: var(--color-background);
    border: none;
    padding: 0.875rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 250ms ease;
  }

  .zinor-product__sticky-atc-btn:hover:not(:disabled),
  .zinor-product__sticky-atc-btn:focus-visible:not(:disabled) {
    background-color: #B58559;
  }

  .zinor-product__sticky-atc-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Respect des préférences utilisateur */
  @media (prefers-reduced-motion: reduce) {
    .zinor-product__image,
    .zinor-accordion__icon::before,
    .zinor-accordion__icon::after,
    .zinor-accordion__panel,
    .zinor-product__sticky-atc,
    .product-lightbox {
      transition: none;
    }
  }
{% endstylesheet %}

